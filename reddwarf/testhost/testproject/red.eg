

object RedObject
{
    dim int m_redInt;

    action RedTest
    {
        for( int i = 0; i < 100; ++i )
        {
            LOG( "RedTest: " << i );
            co_yield eg::sleep();
        }
    }
    
    function RedFunction( int i ) : int
    {
        m_redInt( m_redInt() + i );
        return m_redInt();
    }

}
