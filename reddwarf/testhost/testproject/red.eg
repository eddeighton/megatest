
include( <iostream> );

dim int m_redInt;

action RedTest[ 4 ]
{
    for( int i = 0; i < 100; ++i )
    {
        std::cout << "RedTest: " << i << std::endl;
        co_yield eg::sleep();
    }
}

function RedFunction( int i ) : int
{
    m_redInt( m_redInt() + i );
    return m_redInt();
}
