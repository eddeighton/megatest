
include( <iostream> );
include( <memory> );

include( "sharedIntTraits.hpp" );

dim int m_testHostInt;
dim std::shared_ptr< int > m_pSharedInt;

function InitSharedInt() : void
{
    m_pSharedInt.Get().reset( new int );
}
function ResetSharedInt() : void
{
    m_pSharedInt.Get().reset();
}

function DoTest : void
{
    m_testInt( m_testInt() + 1 );
    std::cout << m_testInt() << std::endl;
}
