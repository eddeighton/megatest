

LOG( "Geometry root created" );


action DumpEdFile
{
    dim std::string m_filePath;
    
    const std::string& strFilePath = m_filePath();
    if( strFilePath.empty() )
    {
        LOG( "Got empty file path in DumpEdFile" );
    }
    else
    {
        dumpEdFile( strFilePath );
    }
}
